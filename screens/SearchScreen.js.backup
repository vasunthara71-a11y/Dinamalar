    color: '#3949ab',
  },
  rankTextTop: { color: '#fff' },

  // Recent chip
  recentChip: {
    flexDirection: 'row',
    alignItems: 'center',
    borderWidth: 0.5,
    borderColor: '#ddd',
    borderRadius: ms(20),
    paddingHorizontal: s(12),
