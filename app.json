{
  "expo": {
    "name": "Dinamalar",
    "slug": "dinamalarmobileapplication",
    "scheme": "dinamalar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/mukta/Mukta_Malar/MuktaMalar-Regular.ttf",
            "./assets/fonts/mukta/Mukta_Malar/MuktaMalar-Bold.ttf",
            "./assets/fonts/mukta/Mukta_Malar/MuktaMalar-Medium.ttf",
            "./assets/fonts/Anek/AnekTamil-Regular.ttf",
            "./assets/fonts/Anek/AnekTamil-Bold.ttf",
            "./assets/fonts/Anek/AnekTamil-Medium.ttf"
          ]
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dinamalarMobileApp",
      "associatedDomains": [
        "applinks:www.dinamalar.com"
      ]
    },
    "android": {
      "package": "com.dinamalarMobileApp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "build": {
      "development": {
        "android": {
          "env": {
            "GOOGLE_SERVICES_JSON": "@google-services-json"
          }
        }
      },
      "preview": {
        "android": {
          "env": {
            "GOOGLE_SERVICES_JSON": "@google-services-json"
          }
        }
      },
      "production": {
        "android": {
          "env": {
            "GOOGLE_SERVICES_JSON": "@google-services-json"
          }
        }
      }
    },
    "extra": {
      "eas": {
        "projectId": "014e592e-d3e5-4958-9178-5ba4e58bd9aa"
      }
    },
    "owner": "dinamalar"
  }
}