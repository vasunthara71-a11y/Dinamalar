{
  "expo": {
    "name": "Dinamalar",
    "slug": "dinamalarmobileapplication",
    "scheme": "dinamalar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/mukta/Mukta_Malar/MuktaMalar-Regular.ttf",
            "./assets/fonts/mukta/Mukta_Malar/MuktaMalar-Bold.ttf",
            "./assets/fonts/mukta/Mukta_Malar/MuktaMalar-Medium.ttf",
            "./assets/fonts/Anek/AnekTamil-Regular.ttf",
            "./assets/fonts/Anek/AnekTamil-Bold.ttf",
            "./assets/fonts/Anek/AnekTamil-Medium.ttf"
          ]
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      "expo-asset",
      "expo-audio",
      "expo-secure-store",
      "expo-sharing",
      "expo-video"
    ],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dinamalarMobileApp",
      "associatedDomains": [
        "applinks:www.dinamalar.com"
      ]
    },

    "android": {
      "package": "com.dinamalarMobileApp",
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "www.dinamalar.com", "path": "/video/*" },
            { "scheme": "https", "host": "www.dinamalar.com", "path": "/videos/*" },
            { "scheme": "https", "host": "dinamalar.com", "path": "/video/*" },
            { "scheme": "https", "host": "dinamalar.com", "path": "/videos/*" },
            { "scheme": "dinamalar", "path": "/video/*" },
            { "scheme": "dinamalar", "path": "/videos/*" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png",
        "backgroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/icon.png"
      },

      "permissions": [
        "INTERNET"
      ]
    },

    "web": {
      "favicon": "./assets/icon.png"
    },

    "extra": {
      "eas": {
        "projectId": "014e592e-d3e5-4958-9178-5ba4e58bd9aa"
      }
    },

    "owner": "dinamalar"
  }
}